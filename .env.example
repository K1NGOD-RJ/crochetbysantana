# ── Google Sheets ─────────────────────────────────────────────
# Paste the full service account JSON as a single line (no newlines inside)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ID from the spreadsheet URL: spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_WRITE_ID=your_sheet_id_here

# ── Auth ──────────────────────────────────────────────────────
# Owner dashboard password (set something strong in Netlify)
OWNER_PASSWORD=change_this_in_production

# ── Email notifications (Resend) ──────────────────────────────
# API key from resend.com — must belong to the account that owns OWNER_EMAIL's domain
RESEND_API_KEY=re_xxxxxxxxxxxxx
OWNER_EMAIL=your_email@example.com
